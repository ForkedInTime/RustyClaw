[0.0, "o", "\u001b[13;1H\u001b[38;2;255;165;0;49m\u250c\u001b[1m rustyclaw v0.2.0 \u001b[22m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[14;1H\u2502\u001b[1m\u001b[38;5;15;49m  Welcome back, yetipaw!\u001b[14;51H\u001b[22m\u001b[38;2;255;165;0;49m\u2502\u001b[14;120H\u2502\u001b[15;1H\u2502\u001b[15;51H\u2502\u001b[1m Tips for getting started\u001b[15;120H\u001b[22m\u2502\u001b[16;1H\u2502\u001b[16;4H\u001b[38;2;240;120;60;49m\u2588\u2588\u2588\u2588  \u2577\u2577\u2577  \u2572\u2572\u2572  \u001b[16;51H\u001b[38;2;255;165;0;49m\u2502\u001b[38;5;15;49m Run /init to create a CLAUDE.md file with instructions\u001b[16;120H\u001b[38;2;255;165;0;49m\u2502\u001b[17;1H\u2502\u001b[17;4H\u001b[38;2;240;120;60;49m\u2588   \u2588 \u2514\u253c\u2518   \u2572\u2572\u2572 \u001b[17;51H\u001b[38;2;255;165;0;49m\u2502\u001b[17;120H\u2502\u001b[18;1H\u2502\u001b[18;4H\u001b[38;2;240;120;60;49m\u2588\u2588\u2588\u2588   \u2502 \u2500\u2500\u25ba \u2572\u2572\u2572\u001b[18;51H\u001b[38;2;255;165;0;49m\u2502 \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500"]
[0.0, "o", "\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[18;120H\u2502\u001b[19;1H\u2502\u001b[19;4H\u001b[38;2;240;120;60;49m\u2588  \u2588            \u001b[19;51H\u001b[38;2;255;165;0;49m\u2502\u001b[1m Recent activity\u001b[19;120H\u001b[22m\u2502\u001b[20;1H\u2502\u001b[20;4H\u001b[38;2;240;120;60;49m\u2588   \u2588           \u001b[20;51H\u001b[38;2;255;165;0;49m\u2502 \u25c6 \u001b[38;5;8;49m[4fa17b5d] \u2014 \u001b[38;5;15;49mwhat does src/session/mod.rs do?\u001b[20;120H\u001b[38;2;255;165;0;49m\u2502\u001b[21;1H\u2502\u001b[21;4H\u001b[38;2;240;120;60;49m                \u001b[21;51H\u001b[38;2;255;165;0;49m\u2502\u001b[38;5;8;49m     Sun Apr 12, 6:14 PM\u001b[21;120H\u001b[38;2;255;165;0;49m\u2502\u001b[22;1H\u2502\u001b[22;51H\u2502 \u25c6 \u001b[38;5;8;49m[3c8de1f5] \u2014 \u001b[38;5;15;49m(empty)\u001b[22;120H\u001b[38;2;255;165;0;49m\u2502\u001b[23;1H\u2502\u001b[23;4H\u001b[38;5;2;49m\u25cf \u001b[38;5;8;49mSonnet 4.6 \u00b7 Chavo del Ocho\u001b[23;51H\u001b[38;2;255;165;0;49m\u2502\u001b[38;5;8;49m     Sat Apr 11, 11:03 PM\u001b[23;120H\u001b[38;2;255;165;0;49m\u2502\u001b[24;1H\u2502\u001b[38;5;8;49m  /mnt/Storage/Projects/RustyClaw\u001b[24;51H\u001b[38;2;255;165;0;49m\u2502 \u25c6 \u001b[38;5;8;49m[320ae2dd] \u2014 \u001b[38;5;15;49mread src/router.rs and explain complexity scoring\u001b[24;120H\u001b[38;2;255;165;0;49m\u2502\u001b[25;1H\u2502\u001b[25;51H\u2502\u001b[38;5;8;49m     Thu Apr 9, 4:46 PM\u001b[25;120H\u001b[38;2;255;165;0;49m\u2502\u001b[26;1H\u2502\u001b[3m\u001b[38;5;7;49m  Grip your codebase.\u001b[26;51H\u001b[23m\u001b[38;2;255;165;0;49m\u2502 \u25c6 \u001b[38;5;8;49m[e50792e7] \u2014 \u001b[38;5;15;49mThe XTR set for Shimano.. and the Yeti bikes.. ho\u2026\u001b[26;120H\u001b[38;2;255;165;0;49m\u2502\u001b[27;1H\u25